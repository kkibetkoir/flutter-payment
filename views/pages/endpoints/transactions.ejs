<div class="docs-container">
    <div class="docs-sidebar">
        <div class="sidebar-sticky">
            <h4>Transactions</h4>
            <ul class="sidebar-nav">
                <li><a href="#fetch">Fetch Transactions</a></li>
                <li><a href="#fee">Get Transaction Fee</a></li>
