        <!-- Fetch Single Card -->
        <div id="fetch" class="endpoint-section">
            <h2>Fetch Single Virtual Card</h2>
            <div class="endpoint-header">
                <span class="method post">POST</span>
                <span class="path"><%= apiBaseUrl %>/api/virtual-cards/fetch</span>
            </div>
            <div class="endpoint-header" style="margin-top: 8px;">
                <span class="method get">GET</span>
                <span class="path"><%= apiBaseUrl %>/api/virtual-cards/fetch/{cardId}</span>
            </div>
            
            <div class="endpoint-description">
                <p>Retrieve detailed information about a specific virtual card.</p>
                <p><strong>Parameters:</strong> id (string) - Card ID</p>
            </div>
            
            <div class="endpoint-tester" data-endpoint="/api/virtual-cards/fetch" data-method="POST">
                <h3>Try it Out</h3>
                <div class="tester-form">
                    <div class="form-group" style="grid-column: span 2;">
                        <label>Card ID *</label>
                        <input type="text" class="test-input" data-field="id" placeholder="Enter card ID" value="df3f2ba4-f137-4ce0-a6e3-3264c5831f17">
                    </div>
                    <button class="btn-test" onclick="testEndpoint(this)">🚀 Test Endpoint</button>
                </div>
                <div class="tester-response">
                    <div class="response-header">
                        <span>Response</span>
                        <button class="response-clear" onclick="clearResponse(this)">Clear</button>
                    </div>
                    <pre class="response-body"><code></code></pre>
                </div>
            </div>
        </div>
        
        <!-- Fund Card -->
        <div id="fund" class="endpoint-section">
            <h2>Fund Virtual Card</h2>
            <div class="endpoint-header">
                <span class="method post">POST</span>
                <span class="path"><%= apiBaseUrl %>/api/virtual-cards/fund</span>
            </div>
            
            <div class="endpoint-description">
                <p>Add funds to an existing virtual card.</p>
                <p><strong>Parameters:</strong> id (string) - Card ID, amount (number), debit_currency (string)</p>
            </div>
            
            <div class="endpoint-tester" data-endpoint="/api/virtual-cards/fund" data-method="POST">
                <h3>Try it Out</h3>
                <div class="tester-form">
                    <div class="form-group">
                        <label>Card ID *</label>
                        <input type="text" class="test-input" data-field="id" placeholder="Enter card ID" value="c6d7f40b-f772-47b7-8136-81256d2f87a2">
                    </div>
                    <div class="form-group">
                        <label>Amount *</label>
                        <input type="number" class="test-input" data-field="amount" value="500" step="0.01">
                    </div>
                    <div class="form-group" style="grid-column: span 2;">
                        <label>Debit Currency</label>
                        <select class="test-input" data-field="debit_currency">
                            <option value="NGN">NGN</option>
                            <option value="USD">USD</option>
                            <option value="KES">KES</option>
                            <option value="GHS">GHS</option>
                        </select>
                    </div>
                    <button class="btn-test" onclick="testEndpoint(this)">🚀 Test Endpoint</button>
                </div>
                <div class="tester-response">
                    <div class="response-header">
                        <span>Response</span>
                        <button class="response-clear" onclick="clearResponse(this)">Clear</button>
                    </div>
                    <pre class="response-body"><code></code></pre>
                </div>
            </div>
            
            <div class="code-example">
                <div class="code-header">
                    <span class="code-language">JavaScript</span>
                    <button class="copy-btn">📋 Copy</button>
                </div>
                <div class="code-block">
                    <pre><code class="language-javascript">const response = await fetch('<%= apiBaseUrl %>/api/virtual-cards/fund', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
        id: 'c6d7f40b-f772-47b7-8136-81256d2f87a2',
        amount: 500,
        debit_currency: 'NGN'
    })
});

const data = await response.json();
console.log(data);
// {
//   "status": "success",
//   "message": "Card funded successfully",
//   "data": null
// }</code></pre>
                </div>
            </div>
        </div>
        
        <!-- Withdraw Funds -->
        <div id="withdraw" class="endpoint-section">
            <h2>Withdraw from Virtual Card</h2>
            <div class="endpoint-header">
                <span class="method post">POST</span>
                <span class="path"><%= apiBaseUrl %>/api/virtual-cards/withdraw</span>
            </div>
            
            <div class="endpoint-description">
                <p>Withdraw existing funds from a virtual card.</p>
                <p><strong>Parameters:</strong> id (string) - Card ID, amount (number)</p>
            </div>
            
            <div class="endpoint-tester" data-endpoint="/api/virtual-cards/withdraw" data-method="POST">
                <h3>Try it Out</h3>
                <div class="tester-form">
                    <div class="form-group">
                        <label>Card ID *</label>
                        <input type="text" class="test-input" data-field="id" placeholder="Enter card ID" value="92b5d258-e85f-4ca6-835d-e0c6fa20d958">
                    </div>
                    <div class="form-group">
                        <label>Amount *</label>
                        <input type="number" class="test-input" data-field="amount" value="10" step="0.01">
                    </div>
                    <button class="btn-test" onclick="testEndpoint(this)">🚀 Test Endpoint</button>
                </div>
                <div class="tester-response">
                    <div class="response-header">
                        <span>Response</span>
                        <button class="response-clear" onclick="clearResponse(this)">Clear</button>
                    </div>
                    <pre class="response-body"><code></code></pre>
                </div>
            </div>
        </div>
        
        <!-- Card Transactions -->
        <div id="transactions" class="endpoint-section">
            <h2>Get Card Transactions</h2>
            <div class="endpoint-header">
                <span class="method post">POST</span>
                <span class="path"><%= apiBaseUrl %>/api/virtual-cards/transactions</span>
            </div>
            <div class="endpoint-header" style="margin-top: 8px;">
                <span class="method get">GET</span>
                <span class="path"><%= apiBaseUrl %>/api/virtual-cards/transactions/{cardId}?from=2020-01-01&to=2024-12-31</span>
            </div>
            
            <div class="endpoint-description">
                <p>Retrieve transaction history for a specific virtual card with date range filtering.</p>
                <p><strong>Parameters:</strong> id (string) - Card ID, from (date), to (date), index (number), size (number)</p>
            </div>
            
            <div class="endpoint-tester" data-endpoint="/api/virtual-cards/transactions" data-method="POST">
                <h3>Try it Out</h3>
                <div class="tester-form">
                    <div class="form-group">
                        <label>Card ID *</label>
                        <input type="text" class="test-input" data-field="id" placeholder="Enter card ID" value="b1405144-3427-4baf-80ea-5c6075a01a74">
                    </div>
                    <div class="form-group">
                        <label>From Date</label>
                        <input type="date" class="test-input" data-field="from" value="2020-01-01">
                    </div>
                    <div class="form-group">
                        <label>To Date</label>
                        <input type="date" class="test-input" data-field="to" value="2024-12-31">
                    </div>
                    <div class="form-group">
                        <label>Index</label>
                        <input type="number" class="test-input" data-field="index" value="0" min="0">
                    </div>
                    <div class="form-group">
                        <label>Size</label>
                        <input type="number" class="test-input" data-field="size" value="10" min="1" max="100">
                    </div>
                    <button class="btn-test" onclick="testEndpoint(this)">🚀 Test Endpoint</button>
                </div>
                <div class="tester-response">
                    <div class="response-header">
                        <span>Response</span>
                        <button class="response-clear" onclick="clearResponse(this)">Clear</button>
                    </div>
                    <pre class="response-body"><code></code></pre>
                </div>
            </div>
        </div>
        
        <!-- Block Card -->
        <div id="block" class="endpoint-section">
            <h2>Block Virtual Card</h2>
            <div class="endpoint-header">
                <span class="method post">POST</span>
                <span class="path"><%= apiBaseUrl %>/api/virtual-cards/block</span>
            </div>
            <div class="endpoint-header" style="margin-top: 8px;">
                <span class="method put">PUT</span>
                <span class="path"><%= apiBaseUrl %>/api/virtual-cards/block/{cardId}</span>
            </div>
            
            <div class="endpoint-description">
                <p>Block a virtual card to prevent further transactions.</p>
                <p><strong>Parameters:</strong> id (string) - Card ID</p>
            </div>
            
            <div class="endpoint-tester" data-endpoint="/api/virtual-cards/block" data-method="POST">
                <h3>Try it Out</h3>
                <div class="tester-form">
                    <div class="form-group" style="grid-column: span 2;">
                        <label>Card ID *</label>
                        <input type="text" class="test-input" data-field="id" placeholder="Enter card ID" value="92b5d258-e85f-4ca6-835d-e0c6fa20d958">
                    </div>
                    <button class="btn-test" onclick="testEndpoint(this)">🚀 Block Card</button>
                </div>
                <div class="tester-response">
                    <div class="response-header">
                        <span>Response</span>
                        <button class="response-clear" onclick="clearResponse(this)">Clear</button>
                    </div>
                    <pre class="response-body"><code></code></pre>
                </div>
            </div>
        </div>
        
        <!-- Unblock Card -->
        <div id="unblock" class="endpoint-section">
            <h2>Unblock Virtual Card</h2>
            <div class="endpoint-header">
                <span class="method post">POST</span>
                <span class="path"><%= apiBaseUrl %>/api/virtual-cards/unblock</span>
            </div>
            <div class="endpoint-header" style="margin-top: 8px;">
                <span class="method put">PUT</span>
                <span class="path"><%= apiBaseUrl %>/api/virtual-cards/unblock/{cardId}</span>
            </div>
            
            <div class="endpoint-description">
                <p>Unblock a previously blocked virtual card.</p>
                <p><strong>Parameters:</strong> id (string) - Card ID</p>
            </div>
            
            <div class="endpoint-tester" data-endpoint="/api/virtual-cards/unblock" data-method="POST">
                <h3>Try it Out</h3>
                <div class="tester-form">
                    <div class="form-group" style="grid-column: span 2;">
                        <label>Card ID *</label>
                        <input type="text" class="test-input" data-field="id" placeholder="Enter card ID" value="92b5d258-e85f-4ca6-835d-e0c6fa20d958">
                    </div>
                    <button class="btn-test" onclick="testEndpoint(this)">🚀 Unblock Card</button>
                </div>
                <div class="tester-response">
                    <div class="response-header">
                        <span>Response</span>
                        <button class="response-clear" onclick="clearResponse(this)">Clear</button>
                    </div>
                    <pre class="response-body"><code></code></pre>
                </div>
            </div>
        </div>
        
        <!-- Terminate Card -->
        <div id="terminate" class="endpoint-section">
            <h2>Terminate Virtual Card</h2>
            <div class="endpoint-header">
                <span class="method post">POST</span>
                <span class="path"><%= apiBaseUrl %>/api/virtual-cards/terminate</span>
            </div>
            <div class="endpoint-header" style="margin-top: 8px;">
                <span class="method delete">DELETE</span>
                <span class="path"><%= apiBaseUrl %>/api/virtual-cards/terminate/{cardId}</span>
            </div>
            
            <div class="endpoint-description">
                <p>Permanently terminate a virtual card. This action cannot be undone.</p>
                <p><strong>Parameters:</strong> id (string) - Card ID</p>
            </div>
            
            <div class="endpoint-tester" data-endpoint="/api/virtual-cards/terminate" data-method="POST">
                <h3>Try it Out</h3>
                <div class="tester-form">
                    <div class="form-group" style="grid-column: span 2;">
                        <label>Card ID *</label>
                        <input type="text" class="test-input" data-field="id" placeholder="Enter card ID" value="c6d7f40b-f772-47b7-8136-81256d2f87a2">
                    </div>
                    <button class="btn-test" onclick="testEndpoint(this)">🚀 Terminate Card</button>
                </div>
                <div class="tester-response">
                    <div class="response-header">
                        <span>Response</span>
                        <button class="response-clear" onclick="clearResponse(this)">Clear</button>
                    </div>
                    <pre class="response-body"><code></code></pre>
                </div>
            </div>
            
            <div class="code-example">
                <div class="code-header">
                    <span class="code-language">JavaScript</span>
                    <button class="copy-btn">📋 Copy</button>
                </div>
                <div class="code-block">
                    <pre><code class="language-javascript">// POST request
const response = await fetch('<%= apiBaseUrl %>/api/virtual-cards/terminate', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
        id: 'c6d7f40b-f772-47b7-8136-81256d2f87a2'
    })
});

// DELETE request
const response2 = await fetch('<%= apiBaseUrl %>/api/virtual-cards/terminate/c6d7f40b-f772-47b7-8136-81256d2f87a2', {
    method: 'DELETE'
});

const data = await response.json();
console.log(data);
// {
//   "status": "success",
//   "message": "Card terminated successfully",
//   "data": null
// }</code></pre>
                </div>
            </div>
        </div>
    </div>
</div>