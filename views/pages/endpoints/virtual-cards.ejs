    </div>
    
    <div class="docs-content">
        <h1>Virtual Cards API</h1>
        <p class="docs-lead">Complete virtual card management for creating, funding, and managing virtual cards.</p>
        
        <!-- Create Virtual Card -->
        <div id="create" class="endpoint-section">
            <h2>Create Virtual Card</h2>
            <div class="endpoint-header">
                <span class="method post">POST</span>
                <span class="path"><%= apiBaseUrl %>/api/virtual-cards/create</span>
            </div>
            
            <div class="endpoint-description">
                <p>Create a new virtual card with the specified currency and amount.</p>
                <p><strong>Required Fields:</strong> currency, amount, billing_name, billing_address, billing_city, billing_state, billing_postal_code, billing_country, first_name, last_name, date_of_birth, email, phone</p>
            </div>
            
            <div class="endpoint-tester" data-endpoint="/api/virtual-cards/create" data-method="POST">
                <h3>Try it Out</h3>
                <div class="tester-form">
                    <div class="form-group">
                        <label>Currency *</label>
                        <select class="test-input" data-field="currency">
                            <option value="USD">USD</option>
                            <option value="NGN">NGN</option>
                            <option value="KES">KES</option>
                            <option value="GHS">GHS</option>
                            <option value="EUR">EUR</option>
                            <option value="GBP">GBP</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Amount *</label>
                        <input type="number" class="test-input" data-field="amount" value="5" step="0.01">
                    </div>
                    <div class="form-group">
                        <label>Debit Currency</label>
                        <select class="test-input" data-field="debit_currency">
                            <option value="NGN">NGN</option>
                            <option value="USD">USD</option>
                            <option value="KES">KES</option>
                            <option value="GHS">GHS</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Billing Name *</label>
                        <input type="text" class="test-input" data-field="billing_name" value="John Doe">
                    </div>
                    <div class="form-group">
                        <label>Billing Address *</label>
                        <input type="text" class="test-input" data-field="billing_address" value="333 Fremont Street">
                    </div>
                    <div class="form-group">
                        <label>Billing City *</label>
                        <input type="text" class="test-input" data-field="billing_city" value="San Francisco">
                    </div>
                    <div class="form-group">
                        <label>Billing State *</label>
                        <input type="text" class="test-input" data-field="billing_state" value="CA">
                    </div>
                    <div class="form-group">
                        <label>Billing Postal Code *</label>
                        <input type="text" class="test-input" data-field="billing_postal_code" value="94105">
                    </div>
                    <div class="form-group">
                        <label>Billing Country *</label>
                        <select class="test-input" data-field="billing_country">
                            <option value="US">US</option>
                            <option value="NG">NG</option>
                            <option value="KE">KE</option>
                            <option value="GH">GH</option>
                            <option value="ZA">ZA</option>
                            <option value="GB">GB</option>
                            <option value="FR">FR</option>
                            <option value="DE">DE</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>First Name *</label>
                        <input type="text" class="test-input" data-field="first_name" value="John">
                    </div>
                    <div class="form-group">
                        <label>Last Name *</label>
                        <input type="text" class="test-input" data-field="last_name" value="Doe">
                    </div>
                    <div class="form-group">
                        <label>Date of Birth *</label>
                        <input type="date" class="test-input" data-field="date_of_birth" value="1996-12-30">
                    </div>
                    <div class="form-group">
                        <label>Email *</label>
                        <input type="email" class="test-input" data-field="email" value="user@example.com">
                    </div>
                    <div class="form-group">
                        <label>Phone *</label>
                        <input type="tel" class="test-input" data-field="phone" value="07030000000">
                    </div>
                    <div class="form-group">
                        <label>Title</label>
                        <select class="test-input" data-field="title">
                            <option value="MR">MR</option>
                            <option value="MS">MS</option>
                            <option value="MRS">MRS</option>
                            <option value="DR">DR</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Gender</label>
                        <select class="test-input" data-field="gender">
                            <option value="M">M</option>
                            <option value="F">F</option>
                        </select>
                    </div>
                    <button class="btn-test" onclick="testEndpoint(this)">🚀 Test Endpoint</button>
                </div>
                <div class="tester-response">
                    <div class="response-header">
                        <span>Response</span>
                        <button class="response-clear" onclick="clearResponse(this)">Clear</button>
                    </div>
                    <pre class="response-body"><code></code></pre>
                </div>
            </div>
            
            <div class="code-example">
                <div class="code-header">
                    <span class="code-language">JavaScript</span>
                    <button class="copy-btn">📋 Copy</button>
                </div>
                <div class="code-block">
                    <pre><code class="language-javascript">const response = await fetch('<%= apiBaseUrl %>/api/virtual-cards/create', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
        currency: 'USD',
        amount: 5,
        debit_currency: 'NGN',
        billing_name: 'John Doe',
        billing_address: '333 Fremont Street',
        billing_city: 'San Francisco',
        billing_state: 'CA',
        billing_postal_code: '94105',
        billing_country: 'US',
        first_name: 'John',
        last_name: 'Doe',
        date_of_birth: '1996-12-30',
        email: 'user@example.com',
        phone: '07030000000',
        title: 'MR',
        gender: 'M'
    })
});

const data = await response.json();
console.log(data);
// {
//   "status": "success",
//   "message": "Card created successfully",
//   "data": {
//     "id": "199a344f-1dbe-4b00-ba4d-beb014345fae",
//     "card_pan": "5319938155020288",
//     "masked_pan": "531993*******0288",
//     "cvv": "905",
//     "expiration": "2025-09",
//     "is_active": true
//   }
// }</code></pre>
                </div>
            </div>
        </div>
        
        <!-- Fetch All Cards -->
        <div id="fetch-all" class="endpoint-section">
            <h2>Fetch All Virtual Cards</h2>
            <div class="endpoint-header">
                <span class="method get">GET</span>
