<section class="quick-start">
    <div class="container">
        <h2>Quick Start</h2>
        <p class="section-subtitle">Start accepting payments in minutes</p>
        
        <div class="code-example">
            <div class="code-header">
                <span class="code-language">JavaScript</span>
                <button class="copy-btn">📋 Copy</button>
            </div>
            <div class="code-block">
                <pre><code class="language-javascript">const API_BASE = '<%= apiBaseUrl %>';

// Initialize payment
const response = await fetch(`${API_BASE}/api/flow/initiate/mpesa`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
        amount: '100',
        currency: 'KES',
        phone: '254712345678',
        email: 'customer@example.com',
        fullname: 'John Doe'
    })
});

const data = await response.json();
console.log('Payment initiated:', data.checkoutId);

// Check payment status
const status = await fetch(`${API_BASE}/api/flow/status`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ checkoutId: data.checkoutId })
});</code></pre>
            </div>
        </div>
    </div>
</section>

