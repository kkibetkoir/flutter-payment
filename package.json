{
  "name": "express-simple-starter",
  "private": true,
  "scripts": {
    "start": "node app.js",
    "start:flow": "node app-flow.js",
    "dev": "nodemon app.js",
    "dev:flow": "nodemon app-flow.js",
    "start:all": "concurrently \"npm run start\" \"npm run start:flow\"",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:flow\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "flutterwave-node-v3": "^1.4.1",
    "http": "^0.0.1-security",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "nodemon": "^3.1.14"
  }
}
